# Public site URL (used in metadata, OG, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://www.thepottersanctuary.co.uk

# Resend transactional email (booking notifications).
# Sign up at https://resend.com and add a verified sending domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where booking enquiries are delivered.
BOOKING_EMAIL_TO=hello@thepottersanctuary.co.uk

# Verified sender address on Resend. Must be on a domain you've verified.
BOOKING_EMAIL_FROM=bookings@thepottersanctuary.co.uk
