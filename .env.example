# Public site URL used in metadata, OG tags and sitemap
NEXT_PUBLIC_SITE_URL=https://www.thepottersanctuary.co.uk

# Supabase project URL — found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — found in Supabase dashboard → Project Settings → API
# Never expose this to the browser. Server/API routes only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key — found in resend.com → API Keys
RESEND_API_KEY=re_your-api-key

# Email address booking notifications are delivered to
BOOKING_EMAIL_TO=hello@thepottersanctuary.co.uk

# Verified sender address on Resend
BOOKING_EMAIL_FROM=bookings@thepottersanctuary.co.uk

# Admin panel login password — set this to something secure
ADMIN_PASSWORD=your-chosen-password
